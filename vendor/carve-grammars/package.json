{
  "name": "@markup-carve/carve-grammars",
  "version": "0.3.0",
  "description": "Grammars for the Carve markup language: Tiptap editor kit + serializer, plus Prism and highlight.js syntax-highlighting grammars",
  "type": "module",
  "main": "tiptap/index.js",
  "scripts": {
    "test": "node tests/serializer-test.js && node tests/grammar-test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markup-carve/carve-grammars.git"
  },
  "keywords": [
    "carve",
    "tiptap",
    "prosemirror",
    "wysiwyg",
    "serializer",
    "markup",
    "syntax-highlighting",
    "prism",
    "prismjs",
    "highlight.js",
    "hljs"
  ],
  "author": "markup-carve",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/markup-carve/carve-grammars/issues"
  },
  "homepage": "https://github.com/markup-carve/carve-grammars#readme",
  "files": [
    "tiptap/",
    "prism/",
    "highlightjs/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./tiptap/index.js",
    "./tiptap": "./tiptap/index.js",
    "./tiptap/*": "./tiptap/*",
    "./prism/carve.js": "./prism/carve.js",
    "./prism/*": "./prism/*",
    "./highlightjs/carve.js": {
      "import": "./highlightjs/carve.mjs",
      "default": "./highlightjs/carve.js"
    },
    "./highlightjs/*": "./highlightjs/*"
  },
  "peerDependencies": {
    "@tiptap/core": "^2",
    "@tiptap/starter-kit": "^2",
    "@tiptap/extension-underline": "^2",
    "prismjs": "^1",
    "highlight.js": "^11"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/extension-underline": {
      "optional": true
    },
    "prismjs": {
      "optional": true
    },
    "highlight.js": {
      "optional": true
    }
  }
}
